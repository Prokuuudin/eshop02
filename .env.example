# Public base URL used for canonical links, Open Graph, JSON-LD, robots and sitemap
# Use production domain with protocol and no trailing slash
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Cloudflare Turnstile (contact form anti-spam)
# Public key used by the client widget
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Secret key used on server for token verification
TURNSTILE_SECRET_KEY=
